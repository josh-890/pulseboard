// ─── Physical Attribute Catalog ──────────────────────────────────────────────

model PhysicalAttributeGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  definitions PhysicalAttributeDefinition[]

  @@index([sortOrder])
}

enum PhysicalAttributeValueType {
  BOOLEAN
  SINGLE_SELECT
  MULTI_SELECT
  ORDINAL
  NUMERIC
  TEXT
}

// Mutability policy on a scalar attribute definition. Drives UI affordance
// and validation only — never modifies stored history (ADR-0005). Reclassifying
// an attribute changes future authoring behaviour immediately and leaves all
// existing ScalarDelta rows untouched.
enum Mutability {
  ALWAYS_STATIC
  RARELY_CHANGES
  VOLATILE
}

// Audit tier on a scalar attribute definition — drives the /maintenance
// baseline-gap audit. TIER_1 = every person should have a value, gap shown
// as a warning. TIER_2 = universal + nice-to-know, gap shown as a hint.
// NONE = not in audit (covers opt-in attrs like Freckles where absence
// is meaningful, and irrelevant catalog plumbing like Glove Size).
enum AuditTier {
  TIER_1
  TIER_2
  NONE
}

// Slice 16E / ADR-0010: which color_catalog category backs an attribute.
// Only set on hair_color / eye-color / skin-tone. Drives ColorValueCombobox
// dispatch in TypedAttributeInput; lookup_* SQL functions read the catalog
// directly via this category.
enum ColorCategory {
  hair
  eye
  skin
}

model PhysicalAttributeDefinition {
  id            String                     @id @default(cuid())
  groupId       String
  group         PhysicalAttributeGroup     @relation(fields: [groupId], references: [id])
  name          String
  slug          String                     @unique
  unit          String?
  valueType     PhysicalAttributeValueType @default(TEXT)
  allowedValues String[]                   @default([])
  ordinalMin    Int?
  ordinalMax    Int?
  mutability    Mutability                 @default(RARELY_CHANGES)
  // Phase G Slice 6½ / ADR-0007 amendment: gates UI surfaces that surface
  // AttributeStatus (sidebar status sub-filter, Pattern Y progression, Cause
  // picker in record-change sheet). Default false; backfilled true only for
  // breast_size.
  statusBearing Boolean                    @default(false)
  // Slice 16 follow-up: maintenance audit tier (TIER_1 warning / TIER_2 hint
  // / NONE = not audited). See AuditTier enum.
  tier          AuditTier                  @default(NONE)
  // Slice 16E / ADR-0010: annotates which catalog entries are backed by
  // color_catalog. Drives TypedAttributeInput's early-routing to
  // ColorValueCombobox. Only set for hair_color / eye-color / skin-tone.
  colorCategory ColorCategory?
  sortOrder     Int                        @default(0)
  createdAt     DateTime                   @default(now())

  cosmeticProcedures CosmeticProcedure[]
  scalarDeltas       ScalarDelta[]

  @@unique([groupId, name])
  @@index([groupId])
  @@index([sortOrder])
}

// One dated change to an identity-less scalar attribute (weight, hair colour,
// build, …) within an Era. Replaces PersonaPhysical + PersonaPhysicalAttribute:
// the folded current value is the latest delta per attribute (ADR-0001). An
// attribute may change more than once in one Era — no eraId+definition unique.
model ScalarDelta {
  id                    String                      @id @default(cuid())
  eraId                 String
  era                   Era                         @relation(fields: [eraId], references: [id])
  attributeDefinitionId String
  attributeDefinition   PhysicalAttributeDefinition @relation(fields: [attributeDefinitionId], references: [id])
  value                 String
  date                  DateTime?
  datePrecision         DatePrecision               @default(UNKNOWN)
  dateModifier          DateModifier                @default(EXACT)
  dateSource            String?
  notes                 String? // raw import provenance, e.g. "import: 'enlarged or fake'"
  cause                 DeltaCause                  @default(NATURAL) // Phase G Slice 4 / ADR-0007
  // Slice 16 follow-up / FHIR-style verified-unknown: true = user
  // explicitly confirmed there's no value for this attribute. The fold
  // writes a "__UNKNOWN__" sentinel into PersonCurrentState.baselineAttributes
  // so existing JSONB key-presence queries see it as populated. Value is
  // forced empty when this is true.
  isVerifiedUnknown     Boolean                     @default(false)
  createdAt             DateTime                    @default(now())

  @@index([eraId])
  @@index([attributeDefinitionId])
  @@index([date])
}

// ─── Derived-State Cache ─────────────────────────────────────────────────────

// Per-person folded current state. Replaces the mv_person_current_state
// materialized view (ADR-0003). One row per person, kept correct in the same
// transaction as every delta mutation via app_recompute_person_current_state().
// Query-shaped: carries every column the search service + facets read.
model PersonCurrentState {
  personId String @id
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  eyeColor         String?
  currentHairColor String?
  currentWeight    Float?
  currentBuild     String?

  // hair / eye / skin classification (catalog-driven via lookup_* functions)
  hairHue           String?
  hairLightness     String?
  hairLightnessRank Int?
  eyeHue            String?
  eyeLightness      String?
  eyeLightnessRank  Int?
  skinTone          String?
  skinToneRank      Int?
  skinUndertone     String?

  currentAttributes  Json @default("{}")
  attributeStatuses  Json @default("{}") // folded NATURAL/ENHANCED/RESTORED — populated in Phase C
  // Slice 16 Step 4 / ADR-0008 principle 4: {slug: value} for baseline-Era
  // deltas only. Drives the "baseline value is missing for attribute X"
  // search filter — the audit hook ADR-0008 commits the product to.
  baselineAttributes Json @default("{}")

  tattooRegions       String[] @default([])
  scarRegions         String[] @default([])
  piercingRegions     String[] @default([])
  modificationRegions String[] @default([])
  procedureRegions    String[] @default([])

  // Phase G Slice 15: union of distinct mark.type + mod.type for the person's
  // present (non-removed) body features. Drives the hero type-presence chips
  // and replaced the per-type has* booleans (dropped 2026-05-31). Search
  // uses array membership against this column instead.
  presentBodyFeatureTypes String[] @default([])

  updatedAt DateTime @default(now())

  @@index([currentAttributes], type: Gin)
  @@index([tattooRegions], type: Gin)
  @@index([scarRegions], type: Gin)
  @@index([piercingRegions], type: Gin)
  @@index([modificationRegions], type: Gin)
  @@index([procedureRegions], type: Gin)
  @@index([presentBodyFeatureTypes], type: Gin)
  @@index([hairHue])
  @@index([hairLightnessRank])
  @@index([eyeHue])
  @@index([eyeLightnessRank])
  @@index([skinToneRank])
  @@index([skinUndertone])
}

