  resolvedArtistId String?
  resolvedArtist   Artist?      @relation(fields: [resolvedArtistId], references: [id])
  resolvedAliasId  String?
  resolvedAlias    PersonAlias? @relation("CreditAlias", fields: [resolvedAliasId], references: [id], onDelete: SetNull)

  @@index([setId])
  @@index([resolutionStatus])
  @@index([nameNorm])
  @@index([resolvedPersonId])
  @@index([resolvedArtistId])
  @@index([resolvedAliasId])
  @@index([roleDefinitionId])
}

model PersonMediaLink {
  id          String           @id @default(cuid())
  personId    String
  person      Person           @relation(fields: [personId], references: [id])
  mediaItemId String
  mediaItem   MediaItem        @relation(fields: [mediaItemId], references: [id])
  usage       PersonMediaUsage
  isFavorite  Boolean          @default(false)
