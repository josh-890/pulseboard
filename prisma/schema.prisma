// ─── Import Pipeline ────────────────────────────────────────────────────────

enum ImportBatchStatus {
  PARSING
  REVIEW
  IMPORTING
  COMPLETED
  FAILED
}

enum ImportItemStatus {
  NEW
  MATCHED
  PROBABLE
  BLOCKED
  // ADR-0009: re-import case (existing person matched by exact ICG-ID).
  // The item waits in this status until the user makes per-attribute
  // Accept/Decline decisions in the review UI. importPerson() refuses
  // to execute items in this status; it requires READY_TO_IMPORT or
  // MATCHED-with-no-pending-decisions.
  PENDING_ATTRIBUTE_REVIEW
  READY_TO_IMPORT
  QUEUED
  IMPORTING
  IMPORTED
  SKIPPED
  FAILED
}

enum ImportItemType {
  PERSON
  PERSON_ALIAS
  DIGITAL_IDENTITY
  CHANNEL
  LABEL
  SET
  CO_MODEL
  CREDIT
}

model Artist {
  id          String   @id @default(cuid())
  name        String
  nameNorm    String
  nationality String?
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creditsRaw SetCreditRaw[]

  @@index([nameNorm])
}

model ImportBatch {
  id              String            @id @default(cuid())
  filename        String
  subjectName     String
  subjectIcgId    String
  status          ImportBatchStatus @default(PARSING)
  rawContent      String
  parsedAt        DateTime?
  notes           String?
  extractionDate  DateTime?
  previousBatchId String?
  previousBatch   ImportBatch?      @relation("BatchHistory", fields: [previousBatchId], references: [id])
  nextBatches     ImportBatch[]     @relation("BatchHistory")
  stagingSummary  Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  items           ImportItem[]
  stagingSets     StagingSet[]
  declineLog      ImportDeclineLog[]

  @@index([subjectIcgId])
  @@map("import_batch")
}

model ImportItem {
  id              String           @id @default(cuid())
  batchId         String
  batch           ImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  type            ImportItemType
  status          ImportItemStatus @default(NEW)
  sortOrder       Int              @default(0)
  data            Json
  rawText         String?
  matchedEntityId String?
  matchConfidence Float?
  matchDetails    String?
  dependsOn       String[]
  blockedReason   String?
  editedData      Json?
  // ADR-0009: in-flight per-attribute decisions for re-imports of existing
  // persons. Populated when matchConfidence=1.0; shape is the diff between
  // the import file's data and the matched person's current state, with
  // per-row Accept/Decline + intent. importPerson() reads this to apply
  // the user-decided Accept set.
  decisions       Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  stagingSets StagingSet[]

  @@index([batchId, type])
  @@index([batchId, status])
  @@map("import_item")
}

// ADR-0009 Phase 2: re-import decision history. Today only `kind='alias'`
// rows are written — scalars are explicitly NOT logged per the
// hair-colour-cycling carve-out, and digital identities use their own SKIP
// flow rather than per-row Decline. `itemKey` is the normalised key
// produced by normaliseAliasKey() in src/lib/services/import/diff.ts.
// Surfaces in the review UI as "Previously declined ..." next to a
// matching row in a later re-import.
model ImportDeclineLog {
  id                String      @id @default(cuid())
  personId          String
  person            Person      @relation(fields: [personId], references: [id], onDelete: Cascade)
  kind              String
  itemKey           String
  declinedInBatchId String
  declinedInBatch   ImportBatch @relation(fields: [declinedInBatchId], references: [id], onDelete: Cascade)
  declinedAt        DateTime    @default(now())

  @@index([personId, kind])
  @@index([declinedAt])
  @@map("import_decline_log")
}

// ADR-0009 Phase 2: manual-deletion record for relation kinds (alias /
// digital identity). Written in the same $transaction as the delete so a
// future re-import surfaces "Previously manually deleted ..." rather than
// silently proposing to re-create. `kind` ∈ {'alias','digital_identity'};
// `itemKey` is the kind-appropriate normalisation.
model ItemDeletionTombstone {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  kind      String
  itemKey   String
  deletedAt DateTime @default(now())

  @@index([personId, kind])
  @@index([deletedAt])
  @@map("item_deletion_tombstone")
}

// ─── Staging Sets ─────────────────────────────────────────────────────────────

enum StagingSetStatus {
  PENDING
  REVIEWING
  APPROVED
  PROMOTED
  INACTIVE
  SKIPPED
}

enum ArchiveStatus {
  UNKNOWN
  PENDING
  OK
  CHANGED
  MISSING
  INCOMPLETE
}

enum ArchiveLinkStatus {
  SUGGESTED
  CONFIRMED
}

model StagingSet {
  id String @id @default(cuid())

  // Raw import data
  title                String
  titleNorm            String?
  externalId           String?
  channelName          String
  channelId            String?
  channel              Channel?      @relation(fields: [channelId], references: [id])
  releaseDate          DateTime?
  releaseDatePrecision DatePrecision @default(UNKNOWN)
  isVideo              Boolean       @default(false)
  imageCount           Int?
  artist               String?
  artistNorm           String?
  coverImageUrl        String?
  description          String?
  participants         Json?
  participantIcgIds    String[]
  participantNamesNorm String?
  participantStatuses  Json?

  // Provenance
  importBatchId   String?
  importBatch     ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  importItemId    String?
  importItem      ImportItem?  @relation(fields: [importItemId], references: [id])
  subjectPersonId String?
  subjectPerson   Person?      @relation("StagingSetSubject", fields: [subjectPersonId], references: [id])
  subjectIcgId    String?

  // Matching
  matchedSetId    String?
  matchedSet      Set?    @relation("StagingSetMatch", fields: [matchedSetId], references: [id])
  matchConfidence Float?
  matchDetails    String?
  // Set ids the user explicitly rejected as a match ("Wrong Match"). The matcher skips
  // these so a fuzzy auto-match (e.g. series "Part 2" → "Part 1") won't keep reappearing.
  rejectedMatchSetIds String[] @default([])

  // Resolution
  status        StagingSetStatus @default(PENDING)
  promotedSetId String?
  promotedSet   Set?             @relation("StagingSetPromoted", fields: [promotedSetId], references: [id])

  // Duplicate/reupload tracking
  duplicateGroupId String?
  isDuplicate      Boolean @default(false)
  isReupload       Boolean @default(false)

  // Date suggestion (extracted from title when Date field is 0000-00-00)
  releaseDateSuggestion String?

  // User annotations
  priority Int?
  notes    String?

  // Media queue
  mediaPriority Int?
  mediaQueueAt  DateTime?

  // Split-set sibling: video staging set points to its photo counterpart
  siblingId String?     @unique
  sibling   StagingSet? @relation("StagingSetSibling", fields: [siblingId], references: [id])
  siblingOf StagingSet? @relation("StagingSetSibling")

  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  coherenceSnapshot SetCoherenceSnapshot?
  archiveLinks      ArchiveLink[]
  basketItems       CoverBasketItem[]     @relation("BasketItemMatch")

  @@unique([importItemId, isVideo])
  @@index([externalId])
  @@index([channelId])
  @@index([channelName])
  @@index([subjectPersonId])
  @@index([subjectIcgId])
  @@index([titleNorm])
  @@index([artistNorm])
  @@index([participantNamesNorm])
  @@index([mediaQueueAt])
  @@index([importBatchId])
  @@index([status])
  @@index([duplicateGroupId])
  // GIN index for `participantIcgIds has <icgId>` (array containment) — used by
  // the per-person career stats/lookups; without it that filter seq-scans.
  @@index([participantIcgIds], type: Gin)
  @@map("staging_set")
}

model PersonResearch {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id])
  title     String
  content   String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personId])
}

// Represents a physical folder discovered on the archive filesystem during a full-walk scan.
// One row per unique absolute path. Persisted across scans; updated on re-scan.
model ArchiveFolder {
  id              String       @id @default(cuid())
  fullPath        String       @unique // absolute path as seen on the scanner host
  relativePath    String? // {channelFolder}\{year}\{folderName} — populated after matching
  isVideo         Boolean
  fileCount       Int? // files in root (photo) or frames\ subfolder (video)
  videoPresent    Boolean? // videosets only: named video file present
  videoFiles      String? // JSON: all video files found in folder root (for picker UI)
  folderName      String // last segment of fullPath
  parsedDate      DateTime? // date parsed from folder name convention
  parsedShortName String? // channel shortName parsed from folder name
  parsedTitle     String? // title remainder parsed from folder name
  archiveLink     ArchiveLink? // one-to-one via ArchiveLink.archiveFolderId @unique
  archiveKey      String       @unique @default(uuid()) // stable folder identity UUID; generated at first scan time (independent of Set/StagingSet link)
  scannedAt       DateTime
  missingOnDisk   Boolean      @default(false) // true = last full scan did not find this path on disk
  tenant          String // which tenant DB this record belongs to

  // Smart scan fields
  contentSignature     String? // SHA256(sorted filename:size) first 16 hex chars — rename fingerprint
  leafDirModifiedAt    DateTime? // leaf folder LastWriteTime — skip file listing if unchanged
  yearDirModifiedAt    DateTime? // year folder LastWriteTime — skip all leaves if unchanged
  chanFolderModifiedAt DateTime? // channelFolder LastWriteTime — skip entire subtree if unchanged
  lastRenamedFrom      String? // previous fullPath — set when rename was detected
  lastRenamedAt        DateTime? // timestamp when rename was detected
  nameFormatOk         Boolean   @default(true) // false = folder name deviates from canonical format
  chanFolderName       String? // channel folder name (e.g. "RA-RylskyArt") — 3rd-from-last path segment

  @@index([folderName])
  @@index([chanFolderName])
  @@index([parsedDate, parsedShortName])
  @@index([tenant])
  @@index([contentSignature])
  @@map("archive_folder")
}

// ─── Coherence ──────────────────────────────────────────────────────────────

// One row per logical set entry — spans Active Set + Staging Set.
// Tracks app-side media presence only; archive state now lives in ArchiveLink.
model SetCoherenceSnapshot {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // At least one must be non-null
  setId        String? @unique
  stagingSetId String? @unique

  // App-side state
  hasMediaInApp Boolean @default(false) // any SetMediaItem exists for setId (imported to MinIO)

  set        Set?        @relation(fields: [setId], references: [id], onDelete: SetNull)
  stagingSet StagingSet? @relation(fields: [stagingSetId], references: [id], onDelete: SetNull)

  @@map("set_coherence_snapshots")
}

// ─── Archive Link ─────────────────────────────────────────────────────────────

// One row per ArchiveFolder — canonical record linking a physical folder to a Set
// or StagingSet. Replaces: ArchiveFolder.linkedSetId, StagingSet.archiveFolderId,
// ArchiveFolder.suggestedSetId/suggestedStagingId, Set/StagingSet archive fields,
// and SetCoherenceSnapshot archive fields.
model ArchiveLink {
  id String @id @default(cuid())

  // Physical folder — always required (one link per folder)
  archiveFolderId String        @unique
  archiveFolder   ArchiveFolder @relation(fields: [archiveFolderId], references: [id], onDelete: Cascade)

  // Target entity (exactly one CONFIRMED at a time enforced via partial unique indexes)
  setId        String?
  set          Set?        @relation(fields: [setId], references: [id])
  stagingSetId String?
  stagingSet   StagingSet? @relation(fields: [stagingSetId], references: [id])

  // State
  status      ArchiveLinkStatus
  confidence  String? // 'HIGH' | 'MEDIUM' (SUGGESTED only)
  confirmedAt DateTime?

  // Scan-verified folder state (mirrors what was previously on Set/StagingSet)
  archivePath          String?
  archiveStatus        ArchiveStatus @default(UNKNOWN)
  archiveFileCount     Int?
  archiveFileCountPrev Int?
  archiveVideoPresent  Boolean?
  archiveVideoFiles    String? // JSON: ["file.mp4", ...]
  archiveVideoFilename String? // user-confirmed video file
  archiveLastChecked   DateTime?
  lastVerifiedAt       DateTime?

  tenant    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([setId])
  @@index([stagingSetId])
  @@index([tenant])
  @@map("ArchiveLink")
}

// ─── Storage Cleanup Queue ───────────────────────────────────────────────────

model OrphanedStorageKey {
  id         String    @id @default(uuid())
  key        String
  reason     String
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([resolvedAt])
  @@map("orphaned_storage_key")
}

// ─── Cover Baskets ────────────────────────────────────────────────────────────

enum CoverBasketItemStatus {
  PENDING // uploaded, no match found yet
  MATCHED // match suggested, awaiting user confirmation
  TRANSFERRED // cover copied to staging set — done
  IGNORED // user dismissed
}

model CoverBasket {
  id        String            @id @default(cuid())
  personId  String
  person    Person            @relation("PersonCoverBaskets", fields: [personId], references: [id], onDelete: Cascade)
  isVideo   Boolean
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  items     CoverBasketItem[]

  @@unique([personId, isVideo])
  @@map("cover_basket")
}

model CoverBasketItem {
  id               String                @id @default(cuid())
  basketId         String
  basket           CoverBasket           @relation(fields: [basketId], references: [id], onDelete: Cascade)
  originalFilename String
  minioKey         String
  fileSize         Int?
  status           CoverBasketItemStatus @default(PENDING)
  matchedSetId     String?
  matchedSet       StagingSet?           @relation("BasketItemMatch", fields: [matchedSetId], references: [id], onDelete: SetNull)
  transferredAt    DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([basketId])
  @@index([matchedSetId])
  @@index([status])
  @@map("cover_basket_item")
}

// ─── Color Catalog (hair / eye / skin classification) ───────────────────────

model ColorCatalog {
  category    String
  valueNorm   String   @map("value_norm")
  display     String
  hue         String
  shade       String?
  shadeRank   Int?     @map("shade_rank")
  sortOrder   Int      @default(0) @map("sort_order")
  needsReview Boolean  @default(false) @map("needs_review")
  // Slice 16E / ADR-0010: gates the ColorValueCombobox dropdown. The full
  // catalog stays preserved; admin curates a working subset by toggling
  // entries off. ColorValueCombobox still surfaces a person's current
  // value with a "(legacy)" tag even when pickable=false, so historical
  // selections never silently vanish.
  pickable    Boolean  @default(true)
  source      String   @default("manual")
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([category, valueNorm])
  @@index([category, hue])
  @@index([category, needsReview])
  @@map("color_catalog")
}

// ─── Saved Searches ──────────────────────────────────────────────────────────

model SavedSearch {
  id         String   @id @default(cuid())
  name       String
  scope      String // "people" (future: "sets", "media")
  filterSpec Json
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([scope, pinned])
  @@map("saved_search")
}
