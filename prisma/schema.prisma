generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PersonStatus {
  active
  inactive
  wishlist
  archived
}

enum WatchPriority {
  HIGH
  NORMAL
  LOW
}

// How a scrape source's URL list is formatted for its external scraper script.
// URL_ONLY = bare URL per line (scraper derives the ICG-ID from the page itself,
// e.g. THENUDE). ICGID_URL = "{icgId}\t{url}" per line, so platforms that can't
// self-identify the person still produce ICG-ID-attributable import files.
enum ScrapeLineFormat {
  URL_ONLY
  ICGID_URL
}

enum AliasSource {
  MANUAL
  IMPORT
}

enum SetType {
  photo
  video
}

enum RelationshipSource {
  derived
  manual
}

enum ProjectStatus {
  active
  paused
  completed
}

enum ActivityType {
  person_added
  set_added
  project_added
  label_added
  session_added
  note
}

enum BodyMarkType {
  tattoo
  scar
  mark
  burn
  deformity
  other
}

enum BodyMarkStatus {
  present
  modified
  removed
}

enum BodyMarkEventType {
  added
  modified
  removed
}

enum DatePrecision {
  UNKNOWN
  YEAR
  MONTH
  DAY
}

enum DateModifier {
  EXACT
  APPROXIMATE
  ESTIMATED
  BEFORE
  AFTER
}

enum BodyModificationType {
  piercing
  stretching
  branding
  scarification
  implant
  teeth
  jewelry
  other
}

enum BodyModificationStatus {
  present
  removed
  overgrown
  modified
}

enum BodyModificationEventType {
  added
  modified
  removed
}

enum CosmeticProcedureEventType {
  performed
  revised
  reversed
}

// Causation flag on deltas + identity-bearing entity events (ADR-0007).
// Drives the NATURAL / ENHANCED / RESTORED derivation: any winning delta with
// cause=SURGICAL flips status to ENHANCED; a subsequent non-SURGICAL delta
// overriding it flips to RESTORED. Default NATURAL.
enum DeltaCause {
  NATURAL
  SURGICAL
  OTHER
}

enum DigitalIdentityStatus {
  active
  inactive
  suspended
  deleted
}

enum DigitalIdentityEventType {
  added
  modified
  removed
}

enum InterestEventType {
  added
  modified
  removed
}

enum EducationType {
  primary
  secondary
  undergraduate
  graduate
  postgraduate
  vocational
  continuing
  other
}

enum AwardType {
  degree
  certificate
  license
  award
  honor
  other
}

enum RelationshipType {
  professional
  personal
  familial
  other
}

enum RelationshipEventType {
  started
  married
  separated
  divorced
  ended
  other
}

enum SessionStatus {
  DRAFT
  CONFIRMED
}

enum SessionType {
  REFERENCE
  PRODUCTION
}

enum MediaType {
  PHOTO
  VIDEO
}

enum ResolutionStatus {
  UNRESOLVED
  RESOLVED
  IGNORED
}

enum EvidenceType {
  CHANNEL_MAP
  MANUAL
}

enum PersonMediaUsage {
  PROFILE
  HEADSHOT
  DETAIL
  PORTFOLIO
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
  EXPERT
}

enum SkillEventType {
  ACQUIRED
  IMPROVED
  DEMONSTRATED
  RETIRED
}

enum ParticipationConfidence {
  CONFIRMED
  PROBABLE
  POSSIBLE
}

enum ConfidenceSource {
  MANUAL
  CREDIT_MATCH
  IMPORT
}

enum TagSource {
  MANUAL
  IMPORT
  AUTO
}

enum ChannelTier {
  PREMIUM
  HIGH
  NORMAL
  LOW
  TRASH
}

// ─── Person & Aliases ─────────────────────────────────────────────────────────

model Person {
  id                  String        @id @default(cuid())
  icgId               String        @unique
  birthdate           DateTime?
  birthdatePrecision  DatePrecision @default(UNKNOWN)
  birthdateModifier   DateModifier  @default(EXACT)
  birthdateSource     String?
  // Slice 16 follow-up: verified-unknown flags for the two Tier 1 Person
  // columns. true = user explicitly confirmed there's no value to record;
  // distinguishes "verified unknown" from "haven't checked yet".
  birthdateUnknown    Boolean       @default(false)
  sexAtBirth          String?
  birthPlace          String?
  nationality         String?
  nationalityUnknown  Boolean       @default(false)
  ethnicity           String?
  location            String?
  // Person.height + Person.eyeColor were dropped in the catalog data quality
  // cleanup (2026-05-31). Both now live as baseline ScalarDeltas under the
  // cattr-height / cattr-eye-color slugs; everything reads from there.
  activeFrom          DateTime?
  activeFromPrecision DatePrecision @default(UNKNOWN)
  activeFromModifier  DateModifier  @default(EXACT)
  activeFromSource    String?
  retiredAt           DateTime?
  retiredAtPrecision  DatePrecision @default(UNKNOWN)
  retiredAtModifier   DateModifier  @default(EXACT)
  retiredAtSource     String?
  birthMarks          String?
  specialization      String?
  status              PersonStatus  @default(active)
  rating              Int?
  pgrade              Int?
  notes               String?
  bio                 String?
  tags                String[]
  // Claimed catalogue size from the imported biography ("… Y photosets, Z videos").
  // Covers (= photosets + videos) is always derived, never stored. The Career-tab
  // stats strip compares these to promoted + staged counts. claimedStatsUserSet is
  // flipped true by a manual edit so later re-imports stop overwriting the values.
  claimedPhotosets    Int?
  claimedVideos       Int?
  claimedStatsUserSet Boolean       @default(false)
  // Free-text provenance for manually-entered claimed figures (e.g. which
  // bio/site they came from). Shown on the Career-tab catalogue panel.
  claimedStatsNote    String?
  // Watchlist: monitor this person for new sets to import. Orthogonal to
  // `status` (a watched person is usually still active). watchCheckedAt is the
  // manual "last looked for new releases" stamp; "last set landed" is derived
  // (max Set.createdAt), not stored. Source links reuse digitalIdentities plus
  // this freeform watchSourceUrl. Surfaced on the /watchlist page + hero toggle.
  watching            Boolean       @default(false)
  watchPriority       WatchPriority @default(NORMAL)
  watchNote           String?
  watchSourceUrl      String?
  watchCheckedAt      DateTime?
  // Per-person pinned attribute slugs (Phase G Slice 2). PhysicalAttributeDefinition
  // slugs the user wants always-visible on the Appearance grid even with no delta.
  // Augments the system-default pinned set in `lib/constants/appearance`.
  pinnedAttributeSlugs String[]      @default([])

  aliases              PersonAlias[]
  eras                 Era[]
  relationships        PersonRelationship[]    @relation("PersonA")
  relatedTo            PersonRelationship[]    @relation("PersonB")
  bodyMarks            BodyMark[]
  digitalIdentities    PersonDigitalIdentity[]
  skills               PersonSkill[]
  bodyModifications    BodyModification[]
  cosmeticProcedures   CosmeticProcedure[]
  education            PersonEducation[]
  awards               PersonAward[]
  interests            PersonInterest[]
  contributions        SessionContribution[]
  setParticipants      SetParticipant[]
  resolvedCredits      SetCreditRaw[]
  personMediaLinks     PersonMediaLink[]
  referenceSession     Session?                @relation("ReferenceSession")
  mediaCollections     MediaCollection[]
  personTags           PersonTag[]
  stagingSetsAsSubject StagingSet[]            @relation("StagingSetSubject")
  research             PersonResearch[]
  coverBaskets         CoverBasket[]           @relation("PersonCoverBaskets")
  currentState         PersonCurrentState?
  importDeclines       ImportDeclineLog[]
  deletionTombstones   ItemDeletionTombstone[]

  createdAt DateTime @default(now())

  @@index([status])
  @@index([watching])
}

model PersonAlias {
  id            String                @id @default(cuid())
  personId      String
  person        Person                @relation(fields: [personId], references: [id])
  name          String
  // isCommon: the name this person is listed under (exactly one per person)
  // isBirth:  the name given at birth (at most one per person)
  // Both flags can be true simultaneously. Neither implies the other.
  // Uniqueness enforced by partial indexes in the DB (not expressible in Prisma SDL).
  isCommon      Boolean               @default(false)
  isBirth       Boolean               @default(false)
  source        AliasSource           @default(MANUAL)
  nameNorm      String?
  notes         String?
  channelLinks  PersonAliasChannel[]
  creditUsages  SetCreditRaw[]        @relation("CreditAlias")
  sessionUsages SessionContribution[] @relation("ContributionAlias")

  @@index([personId])
  @@index([name])
  @@index([nameNorm])
}

model PersonAliasChannel {
  aliasId   String
  alias     PersonAlias @relation(fields: [aliasId], references: [id])
  channelId String
  channel   Channel     @relation(fields: [channelId], references: [id])
  isPrimary Boolean     @default(false)
  notes     String?

  @@id([aliasId, channelId])
  @@index([aliasId])
  @@index([channelId])
}

model Era {
  id            String        @id @default(cuid())
  personId      String
  person        Person        @relation(fields: [personId], references: [id])
  label         String
  notes         String?
  isBaseline    Boolean       @default(false)
  isDraft       Boolean       @default(false)
  date          DateTime?
  datePrecision DatePrecision @default(UNKNOWN)
  dateModifier  DateModifier  @default(EXACT)
  dateSource    String?
  createdAt     DateTime      @default(now())

  scalarDeltas            ScalarDelta[]
  bodyMarkEvents          BodyMarkEvent[]
  digitalIdentities       PersonDigitalIdentity[]
  digitalIdentityEvents   DigitalIdentityEvent[]
  interestEvents          InterestEvent[]
  skills                  PersonSkill[]
  bodyModificationEvents  BodyModificationEvent[]
  cosmeticProcedureEvents CosmeticProcedureEvent[]
  skillEvents             PersonSkillEvent[]
  mediaLinks              PersonMediaLink[]
  contributions           SessionContribution[]

  @@index([personId])
}

model BodyMark {
  id          String         @id @default(cuid())
  personId    String
  person      Person         @relation(fields: [personId], references: [id])
  type        BodyMarkType
  bodyRegion  String
  bodyRegions String[]
  side        String?
  position    String?
  description String?
  motif       String?
  colors      String[]
  size        String?
  status      BodyMarkStatus @default(present)
  // Phase G Slice 15: per-instance heroVisible/heroOrder columns dropped
  // when the hero card switched to type-presence chips driven by
  // PersonCurrentState.presentBodyFeatureTypes.
  createdAt   DateTime       @default(now())

  events           BodyMarkEvent[]
  personMediaLinks PersonMediaLink[]

  @@index([personId])
  @@index([status])
  @@index([bodyRegions], type: Gin)
}

model BodyMarkEvent {
  id            String            @id @default(cuid())
  bodyMarkId    String
  bodyMark      BodyMark          @relation(fields: [bodyMarkId], references: [id])
  eraId         String
  era           Era               @relation(fields: [eraId], references: [id])
  eventType     BodyMarkEventType
  notes         String?
  date          DateTime?
  datePrecision DatePrecision     @default(UNKNOWN)
  dateModifier  DateModifier      @default(EXACT)
  cause         DeltaCause        @default(NATURAL) // Phase G Slice 4 / ADR-0007
  // Property overrides (empty array / null = no change)
  bodyRegions   String[]
  motif         String?
  colors        String[]
  size          String?
  description   String?

  @@index([bodyMarkId])
  @@index([eraId])
  @@index([date])
}

model PersonDigitalIdentity {
  id       String                @id @default(cuid())
  personId String
  person   Person                @relation(fields: [personId], references: [id])
  eraId    String?
  era      Era?                  @relation(fields: [eraId], references: [id])
  platform String
  handle   String?
  url      String?
  status   DigitalIdentityStatus @default(active)
  // Watchlist scan workflow: when an import landed from this page, content is
  // current through here (= the file's extractionDate, advanced monotonically).
  // null = never scanned. excludeFromScan drops a dead/irrelevant page from
  // scan rounds without removing the identity. Scannability is otherwise a
  // property of the page's platform via the ScrapeSource registry.
  scannedThroughAt DateTime?
  excludeFromScan  Boolean   @default(false)

  events DigitalIdentityEvent[]

  @@index([personId])
  @@index([eraId])
  @@index([scannedThroughAt])
}

// Event log for digital-identity lifecycle changes (ADR-0002). Replaces the
// validFrom/validTo interval columns on PersonDigitalIdentity (Phase D).
model DigitalIdentityEvent {
  id                String                   @id @default(cuid())
  digitalIdentityId String
  digitalIdentity   PersonDigitalIdentity    @relation(fields: [digitalIdentityId], references: [id])
  eraId             String
  era               Era                      @relation(fields: [eraId], references: [id])
  eventType         DigitalIdentityEventType
  notes             String?
  date              DateTime?
  datePrecision     DatePrecision            @default(UNKNOWN)
  dateModifier      DateModifier             @default(EXACT)
  // Property overrides (null = no change)
  platform          String?
  handle            String?
  url               String?

  @@index([digitalIdentityId])
  @@index([eraId])
  @@index([date])
}

// Scrape-source registry — the canonical list of external platforms, which of
// them are scrapeable into import files (`isScannable`), how to group a page's
// URL into the per-platform scan file (`fileName`), and the line format that
// platform's scraper expects (`lineFormat`). Subsumes the old hardcoded
// DOMAIN_TO_PLATFORM map: `domains` resolves a profile URL to its platform key.
model ScrapeSource {
  id          String           @id @default(cuid())
  key         String           @unique // normalized platform, e.g. "THENUDE"
  displayName String
  domains     String[]         @default([]) // host suffixes that resolve to this source
  isScannable Boolean          @default(false)
  fileName    String           @default("") // per-platform scan file, e.g. "thenude.txt"
  lineFormat  ScrapeLineFormat @default(ICGID_URL)
  urlPattern  String? // optional hint/validation for this platform's profile URLs
  sortOrder   Int              @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isScannable])
}

model PersonSkill {
  id                String           @id @default(cuid())
  personId          String
  person            Person           @relation(fields: [personId], references: [id])
  eraId             String?
  era               Era?             @relation(fields: [eraId], references: [id])
  skillDefinitionId String?
  skillDefinition   SkillDefinition? @relation(fields: [skillDefinitionId], references: [id])
  name              String
  category          String?
  level             SkillLevel?
  evidence          String?

  events PersonSkillEvent[]

  @@index([personId])
  @@index([eraId])
  @@index([skillDefinitionId])
}

model PersonRelationship {
  id             String             @id @default(cuid())
  personAId      String
  personA        Person             @relation("PersonA", fields: [personAId], references: [id])
  personBId      String
  personB        Person             @relation("PersonB", fields: [personBId], references: [id])
  source         RelationshipSource @default(derived)
  type           RelationshipType?
  label          String?
  sharedSetCount Int                @default(0)
  context        String?

  events RelationshipEvent[]

  @@unique([personAId, personBId])
  @@index([personAId])
  @@index([personBId])
}

// ─── Body Modifications ──────────────────────────────────────────────────────

model BodyModification {
  id          String                 @id @default(cuid())
  personId    String
  person      Person                 @relation(fields: [personId], references: [id])
  type        BodyModificationType
  bodyRegion  String
  bodyRegions String[]
  side        String?
  position    String?
  description String?
  material    String?
  gauge       String?
  status      BodyModificationStatus @default(present)
  // Same drop as BodyMark — type-presence chips replace per-instance pinning.
  createdAt   DateTime               @default(now())

  events           BodyModificationEvent[]
  personMediaLinks PersonMediaLink[]

  @@index([personId])
  @@index([type])
  @@index([status])
  @@index([bodyRegions], type: Gin)
}

model BodyModificationEvent {
  id                 String                    @id @default(cuid())
  bodyModificationId String
  bodyModification   BodyModification          @relation(fields: [bodyModificationId], references: [id])
  eraId              String
  era                Era                       @relation(fields: [eraId], references: [id])
  eventType          BodyModificationEventType
  notes              String?
  date               DateTime?
  datePrecision      DatePrecision             @default(UNKNOWN)
  dateModifier       DateModifier              @default(EXACT)
  cause              DeltaCause                @default(NATURAL) // Phase G Slice 4 / ADR-0007
  // Property overrides (empty array / null = no change)
  bodyRegions        String[]
  description        String?
  material           String?
  gauge              String?

  @@index([bodyModificationId])
  @@index([eraId])
  @@index([date])
}

// ─── Cosmetic Procedures ─────────────────────────────────────────────────────

model CosmeticProcedure {
  id          String   @id @default(cuid())
  personId    String
  person      Person   @relation(fields: [personId], references: [id])
  type        String
  bodyRegion  String
  bodyRegions String[]
  description String?
  provider    String?
  status      String   @default("completed")
  // Same drop as BodyMark/BodyModification. CosmeticProcedure table itself
  // is slated for removal in Slice 17 per ADR-0007.
  createdAt   DateTime @default(now())

  attributeDefinitionId String?
  attributeDefinition   PhysicalAttributeDefinition? @relation(fields: [attributeDefinitionId], references: [id])

  events           CosmeticProcedureEvent[]
  personMediaLinks PersonMediaLink[]

  @@index([personId])
  @@index([bodyRegions], type: Gin)
  @@index([attributeDefinitionId])
}

model CosmeticProcedureEvent {
  id                  String                     @id @default(cuid())
  cosmeticProcedureId String
  cosmeticProcedure   CosmeticProcedure          @relation(fields: [cosmeticProcedureId], references: [id])
  eraId               String
  era                 Era                        @relation(fields: [eraId], references: [id])
  eventType           CosmeticProcedureEventType
  notes               String?
  date                DateTime?
  datePrecision       DatePrecision              @default(UNKNOWN)
  dateModifier        DateModifier               @default(EXACT)
  // Property overrides (empty array / null = no change)
  bodyRegions         String[]
  description         String?
  provider            String?
  // Observation fields (before/after values for procedures that change measurements)
  valueBefore         String?
  valueAfter          String?
  unit                String?

  @@index([cosmeticProcedureId])
  @@index([eraId])
  @@index([date])
}

// ─── Education & Awards ──────────────────────────────────────────────────────

model PersonEducation {
  id                 String        @id @default(cuid())
  personId           String
  person             Person        @relation(fields: [personId], references: [id])
  type               EducationType
  institution        String
  field              String?
  degree             String?
  startDate          DateTime?
  startDatePrecision DatePrecision @default(UNKNOWN)
  endDate            DateTime?
  endDatePrecision   DatePrecision @default(UNKNOWN)
  notes              String?
  createdAt          DateTime      @default(now())

  @@index([personId])
}

model PersonAward {
  id            String        @id @default(cuid())
  personId      String
  person        Person        @relation(fields: [personId], references: [id])
  type          AwardType
  name          String
  issuer        String?
  date          DateTime?
  datePrecision DatePrecision @default(UNKNOWN)
  context       String?
  url           String?
  createdAt     DateTime      @default(now())

  @@index([personId])
}

// ─── Interests ───────────────────────────────────────────────────────────────

model PersonInterest {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id])
  name      String
  category  String?
  level     String?
  notes     String?
  createdAt DateTime @default(now())

  events InterestEvent[]

  @@index([personId])
}

// Event log for interest lifecycle changes (ADR-0002). Replaces the
// validFrom/validTo interval columns on PersonInterest (Phase D).
model InterestEvent {
  id            String            @id @default(cuid())
  interestId    String
  interest      PersonInterest    @relation(fields: [interestId], references: [id])
  eraId         String
  era           Era               @relation(fields: [eraId], references: [id])
  eventType     InterestEventType
  notes         String?
  date          DateTime?
  datePrecision DatePrecision     @default(UNKNOWN)
  dateModifier  DateModifier      @default(EXACT)
  // Property overrides (null = no change)
  name          String?
  category      String?
  level         String?

  @@index([interestId])
  @@index([eraId])
  @@index([date])
}

// ─── Relationship Events ─────────────────────────────────────────────────────

model RelationshipEvent {
  id             String                @id @default(cuid())
  relationshipId String
  relationship   PersonRelationship    @relation(fields: [relationshipId], references: [id])
  eventType      RelationshipEventType
  date           DateTime?
  datePrecision  DatePrecision         @default(UNKNOWN)
  notes          String?
  createdAt      DateTime              @default(now())

  @@index([relationshipId])
}

// ─── Organizations ────────────────────────────────────────────────────────────

model Network {
  id          String  @id @default(cuid())
  name        String
  nameNorm    String?
  description String?
  website     String?

  labelMemberships LabelNetworkLink[]

  @@index([name])
  @@index([nameNorm])
}

model Label {
  id          String  @id @default(cuid())
  name        String
  nameNorm    String?
  description String?
  website     String?

  networks        LabelNetworkLink[]
  projects        ProjectLabel[]
  primaryProjects Project[]          @relation("PrimaryLabel")
  sessions        Session[]
  channelMaps     ChannelLabelMap[]
  labelEvidence   SetLabelEvidence[]

  @@index([name])
  @@index([nameNorm])
}

model LabelNetworkLink {
  labelId   String
  label     Label   @relation(fields: [labelId], references: [id])
  networkId String
  network   Network @relation(fields: [networkId], references: [id])

  @@id([labelId, networkId])
  @@index([networkId])
  @@map("LabelNetwork")
}

model Channel {
  id            String      @id @default(cuid())
  name          String
  nameNorm      String?
  shortName     String?     @unique
  url           String?
  platform      String?
  notes         String?
  importAliases String[]    @default([])
  tier          ChannelTier @default(NORMAL)
  channelFolder String?

  sets        Set[]
  labelMaps   ChannelLabelMap[]
  aliasLinks  PersonAliasChannel[]
  stagingSets StagingSet[]

  @@index([nameNorm])
}

// ─── Evidence Layer ──────────────────────────────────────────────────────────

model ChannelLabelMap {
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id])
  labelId    String
  label      Label    @relation(fields: [labelId], references: [id])
  confidence Float    @default(1.0)
  notes      String?
  createdAt  DateTime @default(now())

  @@id([channelId, labelId])
}

model SetLabelEvidence {
  setId        String
  set          Set          @relation(fields: [setId], references: [id])
  labelId      String
  label        Label        @relation(fields: [labelId], references: [id])
  evidenceType EvidenceType
  confidence   Float        @default(1.0)
  notes        String?
  createdAt    DateTime     @default(now())

  @@id([setId, labelId, evidenceType])
}

// ─── Production ───────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  nameNorm    String?
  description String?
  status      ProjectStatus @default(active)
  tags        String[]
  labelId     String?
  label       Label?        @relation("PrimaryLabel", fields: [labelId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  labels      ProjectLabel[]
  sessions    Session[]
  projectTags ProjectTag[]

  @@index([status])
  @@index([updatedAt])
  @@index([nameNorm])
  @@index([labelId])
}

model ProjectLabel {
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  labelId   String
  label     Label   @relation(fields: [labelId], references: [id])

  @@id([projectId, labelId])
}

model Session {
  id              String        @id @default(cuid())
  projectId       String?
  project         Project?      @relation(fields: [projectId], references: [id])
  labelId         String?
  label           Label?        @relation(fields: [labelId], references: [id])
  personId        String?       @unique
  person          Person?       @relation("ReferenceSession", fields: [personId], references: [id])
  name            String
  nameNorm        String?
  description     String?
  location        String?
  type            SessionType   @default(PRODUCTION)
  status          SessionStatus @default(DRAFT)
  notes           String?
  date            DateTime?
  datePrecision   DatePrecision @default(UNKNOWN)
  dateModifier    DateModifier  @default(EXACT)
  dateSource      String?
  dateIsConfirmed Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  coverMediaItemId String?
  coverMediaItem   MediaItem? @relation("SessionCoverMedia", fields: [coverMediaItemId], references: [id])

  tags            String[]              @default([])
  mediaItems      MediaItem[]
  contributions   SessionContribution[]
  setSessionLinks SetSession[]
  sessionTags     SessionTag[]

  @@index([projectId])
  @@index([labelId])
  @@index([personId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@index([nameNorm])
  @@index([tags], type: Gin)
  @@index([coverMediaItemId])
}

model Set {
  id                   String        @id @default(cuid())
  channelId            String?
  channel              Channel?      @relation(fields: [channelId], references: [id])
  type                 SetType
  title                String
  titleNorm            String?
  description          String?
  notes                String?
  releaseDate          DateTime?
  releaseDatePrecision DatePrecision @default(UNKNOWN)
  releaseDateModifier  DateModifier  @default(EXACT)
  releaseDateSource    String?
  coverMediaItemId     String?
  coverMediaItem       MediaItem?    @relation("SetCoverMedia", fields: [coverMediaItemId], references: [id])
  category             String?
  genre                String?
  tags                 String[]
  isCompilation        Boolean       @default(false)
  isComplete           Boolean       @default(false)
  imageCount           Int?
  videoLength          String?
  externalId           String?       @unique // External source ID (e.g., CoverId from import files)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Subjective star rating (1-5, nullable = unrated). Mirrors Person.rating.
  // Surfaced as a 5-star widget on the set detail page hero and as a
  // multi-select filter on the /sets browser.
  rating               Int?

  // Media queue
  mediaPriority Int?
  mediaQueueAt  DateTime?

  setMediaItems     SetMediaItem[]
  creditsRaw        SetCreditRaw[]
  participants      SetParticipant[]
  labelEvidence     SetLabelEvidence[]
  sessionLinks      SetSession[]
  setTags           SetTag[]
  stagingMatches    StagingSet[]          @relation("StagingSetMatch")
  stagingPromotions StagingSet[]          @relation("StagingSetPromoted")
  coherenceSnapshot SetCoherenceSnapshot?
  archiveLinks      ArchiveLink[]

  @@index([channelId])
  @@index([type])
  @@index([releaseDate])
  @@index([titleNorm])
  @@index([coverMediaItemId])
  @@index([mediaQueueAt])
}

// ─── Media ───────────────────────────────────────────────────────────────────

model MediaItem {
  id                  String        @id @default(cuid())
  sessionId           String
  session             Session       @relation(fields: [sessionId], references: [id])
  mediaType           MediaType
  capturedAt          DateTime?
  capturedAtPrecision DatePrecision @default(UNKNOWN)

  filename       String
  fileRef        String?
  mimeType       String
  size           Int
  hash           String?
  phash          String?
  originalWidth  Int
  originalHeight Int
  durationMs     Int?
  variants       Json?

  focalX       Float?
  focalY       Float?
  focalSource  String?
  focalStatus  String?
  modelVersion String?

  sourceVideoRef   String? // free-text clip name; groups frames from same video clip
  sourceTimecodeMs Int? // timecode offset (ms) at which this frame was extracted

  caption      String?
  tags         String[]
  notes        String?
  isAnnotation Boolean  @default(false) // Derived/edited photos — hidden from main gallery

  // Motif normalization: when set, this MediaItem is a baked, template-aligned
  // "standardized motif" image (e.g. a headshot). The headshot/card path displays
  // it via an aspect-preserving variant (not the 4:5 profile crop). motifProvenance
  // = { sourceMediaItemId, points, matrix } so it can be re-opened and re-baked.
  motifTemplateId String?
  motifTemplate   MotifTemplate? @relation(fields: [motifTemplateId], references: [id], onDelete: SetNull)
  motifProvenance Json?

  // Provenance for the "copy production image → person reference session"
  // feature. Self-FK; null for direct uploads / imports / annotations.
  // SetNull on source delete — copies are independent assets and survive
  // their origin disappearing, just losing the breadcrumb.
  copiedFromMediaItemId String?
  copiedFromMediaItem   MediaItem?  @relation("MediaItemCopySource", fields: [copiedFromMediaItemId], references: [id], onDelete: SetNull)
  copies                MediaItem[] @relation("MediaItemCopySource")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  setMediaItems    SetMediaItem[]
  personMediaLinks PersonMediaLink[]
  coverForSets     Set[]                 @relation("SetCoverMedia")
  coverForSessions Session[]             @relation("SessionCoverMedia")
  collectionItems  MediaCollectionItem[]
  skillEventMedia  SkillEventMedia[]
  mediaItemTags    MediaItemTag[]

  @@index([sessionId])
  @@index([hash])
  @@index([phash])
  @@index([mediaType])
  @@index([tags], type: Gin)
  @@index([copiedFromMediaItemId])
  @@index([motifTemplateId])
}

// A "standardized motif" definition for a profile slot: the output geometry +
// the target keypoint positions an aligned image must hit, so the same motif
// (e.g. headshot eye-line/zoom) is framed identically across people. Authored in
// the Motif Templates catalog; consumed by the Motif Aligner. One per slot.
model MotifTemplate {
  id            String   @id @default(cuid())
  name          String
  slot          Int      @unique // profile slot this template fills (1..N)
  aspectW       Int
  aspectH       Int
  bakeLongSide  Int // baked output long side in px (never upscaled beyond source)
  keypoints     Json // [{ name, x, y }] target positions as 0..1 frame fractions
  silhouetteRef String? // optional overlay image (MinIO key) shown while aligning
  silhouetteTransform Json? // {offsetXFrac,offsetYFrac,scale,rotationDeg,opacity} for the editor underlay
  minSourcePx   Int? // warn-but-allow threshold for the aligned region
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  normalizedImages MediaItem[]
}

model SetMediaItem {
  setId       String
  set         Set       @relation(fields: [setId], references: [id])
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id])
  sortOrder   Int       @default(0)
  isCover     Boolean   @default(false)
  caption     String?
  notes       String?

  @@id([setId, mediaItemId])
}

model SessionContribution {
  id                 String                     @id @default(cuid())
  sessionId          String
  session            Session                    @relation(fields: [sessionId], references: [id])
  personId           String
  person             Person                     @relation(fields: [personId], references: [id])
  roleDefinitionId   String
  roleDefinition     ContributionRoleDefinition @relation(fields: [roleDefinitionId], references: [id])
  creditNameOverride String?
  notes              String?
  confidence         ParticipationConfidence    @default(CONFIRMED)
  confidenceSource   ConfidenceSource           @default(MANUAL)
  confirmedAt        DateTime?
  createdAt          DateTime                   @default(now())
  resolvedAliasId    String?
  resolvedAlias      PersonAlias?               @relation("ContributionAlias", fields: [resolvedAliasId], references: [id], onDelete: SetNull)
  // Phase F — optional link to the Era this person was in at the time of the
  // shoot. Authored on the source-of-truth contribution (not on SetParticipant,
  // a derived cache). Drives the appearance-at-shoot snapshot via the
  // point-in-time fold. Nullable: imports + legacy rows leave it null.
  eraId              String?
  era                Era?                       @relation(fields: [eraId], references: [id], onDelete: SetNull)

  skills ContributionSkill[]

  @@unique([sessionId, personId, roleDefinitionId])
  @@index([resolvedAliasId])
  @@index([sessionId])
  @@index([personId])
  @@index([roleDefinitionId])
  @@index([eraId])
}

model SetParticipant {
  setId            String
  set              Set                        @relation(fields: [setId], references: [id])
  personId         String
  person           Person                     @relation(fields: [personId], references: [id])
  roleDefinitionId String
  roleDefinition   ContributionRoleDefinition @relation(fields: [roleDefinitionId], references: [id])
  confidence       ParticipationConfidence    @default(CONFIRMED)
  confidenceSource ConfidenceSource           @default(MANUAL)
  confirmedAt      DateTime?

  @@id([setId, personId, roleDefinitionId])
  @@index([roleDefinitionId])
}

model SetSession {
  setId     String
  set       Set      @relation(fields: [setId], references: [id])
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@id([setId, sessionId])
  // PK (setId, sessionId) can't seek by sessionId alone; needed for the
  // Session→SetSession hop in per-person Set counts/timelines.
  @@index([sessionId])
}

model SetCreditRaw {
  id               String                      @id @default(cuid())
  setId            String
  set              Set                         @relation(fields: [setId], references: [id])
  roleDefinitionId String?
  roleDefinition   ContributionRoleDefinition? @relation(fields: [roleDefinitionId], references: [id])
  rawName          String
  nameNorm         String?                     @map("rawNameNorm")
  resolutionStatus ResolutionStatus            @default(UNRESOLVED)
  resolvedPersonId String?
