generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum PersonStatus {
  active
  inactive
  wishlist
  archived
}

enum AliasType {
  common
  birth
  alias
}

enum AliasSource {
  MANUAL
  IMPORT
}

enum SetType {
  photo
  video
}

enum RelationshipSource {
  derived
  manual
}

enum ProjectStatus {
  active
  paused
  completed
}

enum ActivityType {
  person_added
  set_added
  project_added
  label_added
  session_added
  note
}

enum BodyMarkType {
  tattoo
  scar
  mark
  burn
  deformity
  other
}

enum BodyMarkStatus {
  present
  modified
  removed
}

enum BodyMarkEventType {
  added
  modified
  removed
}

enum DatePrecision {
  UNKNOWN
  YEAR
  MONTH
  DAY
}

enum BodyModificationType {
  piercing
  stretching
  branding
  scarification
  implant
  teeth
  jewelry
  other
}

enum BodyModificationStatus {
  present
  removed
  overgrown
  modified
}

enum BodyModificationEventType {
  added
  modified
  removed
}

enum CosmeticProcedureEventType {
  performed
  revised
  reversed
}

enum DigitalIdentityStatus {
  active
  inactive
  suspended
  deleted
}

enum EducationType {
  primary
  secondary
  undergraduate
  graduate
  postgraduate
  vocational
  continuing
  other
}

enum AwardType {
  degree
  certificate
  license
  award
  honor
  other
}

enum RelationshipType {
  professional
  personal
  familial
  other
}

enum RelationshipEventType {
  started
  married
  separated
  divorced
  ended
  other
}

enum SessionStatus {
  DRAFT
  CONFIRMED
}

enum SessionType {
  REFERENCE
  PRODUCTION
}

enum MediaType {
  PHOTO
  VIDEO
}

enum ResolutionStatus {
  UNRESOLVED
  RESOLVED
  IGNORED
}

enum EvidenceType {
  CHANNEL_MAP
  MANUAL
}

enum PersonMediaUsage {
  PROFILE
  HEADSHOT
  DETAIL
  PORTFOLIO
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
  EXPERT
}

enum SkillEventType {
  ACQUIRED
  IMPROVED
  DEMONSTRATED
  RETIRED
}

// ─── Person & Aliases ─────────────────────────────────────────────────────────

model Person {
  id             String  @id @default(cuid())
  icgId          String  @unique
  birthdate      DateTime?
  birthdatePrecision DatePrecision @default(UNKNOWN)
  sexAtBirth     String?
  birthPlace     String?
  nationality    String?
  ethnicity      String?
  location       String?
  height         Int?
  naturalHairColor String?
  eyeColor       String?
  bodyType       String?
  measurements   String?
  activeSince    Int?
  retiredIn      Int?
  birthMarks     String?
  specialization String?
  status         PersonStatus @default(active)
  rating         Int?
  pgrade         Int?
  notes          String?
  bio            String?
  tags           String[]

  aliases          PersonAlias[]
  personas         Persona[]
  relationships    PersonRelationship[] @relation("PersonA")
  relatedTo        PersonRelationship[] @relation("PersonB")
  bodyMarks        BodyMark[]
  digitalIdentities PersonDigitalIdentity[]
  skills           PersonSkill[]
  bodyModifications    BodyModification[]
  cosmeticProcedures   CosmeticProcedure[]
  education            PersonEducation[]
  awards               PersonAward[]
  interests            PersonInterest[]
  contributions        SessionContribution[]
  setParticipants      SetParticipant[]
  resolvedCredits      SetCreditRaw[]
  personMediaLinks     PersonMediaLink[]
  referenceSession     Session?             @relation("ReferenceSession")
  mediaCollections     MediaCollection[]

  createdAt DateTime  @default(now())

  @@index([status])
}

model PersonAlias {
  id           String               @id @default(cuid())
  personId     String
  person       Person               @relation(fields: [personId], references: [id])
  name         String
  type         AliasType            @default(alias)
  source       AliasSource          @default(MANUAL)
  nameNorm     String?
  notes        String?
  channelLinks PersonAliasChannel[]

  @@index([personId])
  @@index([name])
  @@index([nameNorm])
}

model PersonAliasChannel {
  aliasId   String
  alias     PersonAlias @relation(fields: [aliasId], references: [id])
  channelId String
  channel   Channel     @relation(fields: [channelId], references: [id])
  isPrimary Boolean     @default(false)
  notes     String?

  @@id([aliasId, channelId])
  @@index([aliasId])
  @@index([channelId])
}

model Persona {
  id         String    @id @default(cuid())
  personId   String
  person     Person    @relation(fields: [personId], references: [id])
  label      String
  notes      String?
  isBaseline Boolean   @default(false)
  date       DateTime?
  datePrecision DatePrecision @default(UNKNOWN)
  createdAt  DateTime  @default(now())

  physicalChange    PersonaPhysical?
  bodyMarkEvents    BodyMarkEvent[]
  digitalIdentities PersonDigitalIdentity[]
  skills            PersonSkill[]
  bodyModificationEvents    BodyModificationEvent[]
  cosmeticProcedureEvents   CosmeticProcedureEvent[]
  skillEvents               PersonSkillEvent[]
  mediaLinks                PersonMediaLink[]

  @@index([personId])
}

model PersonaPhysical {
  id              String  @id @default(cuid())
  personaId       String  @unique
  persona         Persona @relation(fields: [personaId], references: [id])
  weight          Float?
  currentHairColor String?
  build           String?

  attributes      PersonaPhysicalAttribute[]
}

model BodyMark {
  id          String         @id @default(cuid())
  personId    String
  person      Person         @relation(fields: [personId], references: [id])
  type        BodyMarkType
  bodyRegion  String
  bodyRegions String[]
  side        String?
  position    String?
  description String?
  motif       String?
  colors      String[]
  size        String?
  status      BodyMarkStatus @default(present)
  heroVisible Boolean        @default(true)
  heroOrder   Int?
  createdAt   DateTime       @default(now())

  events          BodyMarkEvent[]
  personMediaLinks PersonMediaLink[]

  @@index([personId])
  @@index([status])
  @@index([bodyRegions], type: Gin)
}

model BodyMarkEvent {
  id          String            @id @default(cuid())
  bodyMarkId  String
  bodyMark    BodyMark          @relation(fields: [bodyMarkId], references: [id])
  personaId   String
  persona     Persona           @relation(fields: [personaId], references: [id])
  eventType   BodyMarkEventType
  notes       String?
  // Property overrides (empty array / null = no change)
  bodyRegions String[]
  motif       String?
  colors      String[]
  size        String?
  description String?

  @@index([bodyMarkId])
  @@index([personaId])
}

model PersonDigitalIdentity {
  id        String    @id @default(cuid())
  personId  String
  person    Person    @relation(fields: [personId], references: [id])
  personaId String?
  persona   Persona?  @relation(fields: [personaId], references: [id])
  platform  String
  handle    String?
  url       String?
  status    DigitalIdentityStatus @default(active)
  validFrom DateTime?
  validFromPrecision DatePrecision @default(UNKNOWN)
  validTo   DateTime?
  validToPrecision   DatePrecision @default(UNKNOWN)

  @@index([personId])
  @@index([personaId])
}

model PersonSkill {
  id                String           @id @default(cuid())
  personId          String
  person            Person           @relation(fields: [personId], references: [id])
  personaId         String?
  persona           Persona?         @relation(fields: [personaId], references: [id])
  skillDefinitionId String?
  skillDefinition   SkillDefinition? @relation(fields: [skillDefinitionId], references: [id])
  name              String
  category          String?
  level             SkillLevel?
  evidence          String?
  validFrom         DateTime?
  validFromPrecision DatePrecision   @default(UNKNOWN)
  validTo           DateTime?
  validToPrecision   DatePrecision   @default(UNKNOWN)

  events PersonSkillEvent[]

  @@index([personId])
  @@index([personaId])
  @@index([skillDefinitionId])
}

model PersonRelationship {
  id            String             @id @default(cuid())
  personAId     String
  personA       Person             @relation("PersonA", fields: [personAId], references: [id])
  personBId     String
  personB       Person             @relation("PersonB", fields: [personBId], references: [id])
  source        RelationshipSource @default(derived)
  type          RelationshipType?
  label         String?
  sharedSetCount Int               @default(0)
  validFrom     DateTime?
  validFromPrecision DatePrecision @default(UNKNOWN)
  validTo       DateTime?
  validToPrecision   DatePrecision @default(UNKNOWN)
  context       String?

  events RelationshipEvent[]

  @@unique([personAId, personBId])
  @@index([personAId])
  @@index([personBId])
}

// ─── Body Modifications ──────────────────────────────────────────────────────

model BodyModification {
  id          String  @id @default(cuid())
  personId    String
  person      Person  @relation(fields: [personId], references: [id])
  type        BodyModificationType
  bodyRegion  String
  bodyRegions String[]
  side        String?
  position    String?
  description String?
  material    String?
  gauge       String?
  status      BodyModificationStatus @default(present)
  heroVisible Boolean               @default(true)
  heroOrder   Int?
  createdAt   DateTime  @default(now())

  events          BodyModificationEvent[]
  personMediaLinks PersonMediaLink[]

  @@index([personId])
  @@index([type])
  @@index([status])
  @@index([bodyRegions], type: Gin)
}

model BodyModificationEvent {
  id                 String  @id @default(cuid())
  bodyModificationId String
  bodyModification   BodyModification @relation(fields: [bodyModificationId], references: [id])
  personaId          String
  persona            Persona @relation(fields: [personaId], references: [id])
  eventType          BodyModificationEventType
  notes              String?
  // Property overrides (empty array / null = no change)
  bodyRegions        String[]
  description        String?
  material           String?
  gauge              String?

  @@index([bodyModificationId])
  @@index([personaId])
}

// ─── Cosmetic Procedures ─────────────────────────────────────────────────────

model CosmeticProcedure {
  id          String  @id @default(cuid())
  personId    String
  person      Person  @relation(fields: [personId], references: [id])
  type        String
  bodyRegion  String
  bodyRegions String[]
  description String?
  provider    String?
  status      String  @default("completed")
  heroVisible Boolean @default(true)
  heroOrder   Int?
  createdAt   DateTime  @default(now())

  attributeDefinitionId String?
  attributeDefinition   PhysicalAttributeDefinition? @relation(fields: [attributeDefinitionId], references: [id])

  events          CosmeticProcedureEvent[]
  personMediaLinks PersonMediaLink[]

  @@index([personId])
  @@index([bodyRegions], type: Gin)
  @@index([attributeDefinitionId])
}

model CosmeticProcedureEvent {
  id                  String  @id @default(cuid())
  cosmeticProcedureId String
  cosmeticProcedure   CosmeticProcedure @relation(fields: [cosmeticProcedureId], references: [id])
  personaId           String
  persona             Persona @relation(fields: [personaId], references: [id])
  eventType           CosmeticProcedureEventType
  notes               String?
  // Property overrides (empty array / null = no change)
  bodyRegions         String[]
  description         String?
  provider            String?
  // Observation fields (before/after values for procedures that change measurements)
  valueBefore         String?
  valueAfter          String?
  unit                String?

  @@index([cosmeticProcedureId])
  @@index([personaId])
}

// ─── Education & Awards ──────────────────────────────────────────────────────

model PersonEducation {
  id            String  @id @default(cuid())
  personId      String
  person        Person  @relation(fields: [personId], references: [id])
  type          EducationType
  institution   String
  field         String?
  degree        String?
  startDate     DateTime?
  startDatePrecision DatePrecision @default(UNKNOWN)
  endDate       DateTime?
  endDatePrecision   DatePrecision @default(UNKNOWN)
  notes         String?
  createdAt     DateTime @default(now())

  @@index([personId])
}

model PersonAward {
  id            String  @id @default(cuid())
  personId      String
  person        Person  @relation(fields: [personId], references: [id])
  type          AwardType
  name          String
  issuer        String?
  date          DateTime?
  datePrecision DatePrecision @default(UNKNOWN)
  context       String?
  url           String?
  createdAt     DateTime @default(now())

  @@index([personId])
}

// ─── Interests ───────────────────────────────────────────────────────────────

model PersonInterest {
  id            String  @id @default(cuid())
  personId      String
  person        Person  @relation(fields: [personId], references: [id])
  name          String
  category      String?
  level         String?
  validFrom     DateTime?
  validFromPrecision DatePrecision @default(UNKNOWN)
  validTo       DateTime?
  validToPrecision   DatePrecision @default(UNKNOWN)
  notes         String?
  createdAt     DateTime @default(now())

  @@index([personId])
}

// ─── Relationship Events ─────────────────────────────────────────────────────

model RelationshipEvent {
  id              String  @id @default(cuid())
  relationshipId  String
  relationship    PersonRelationship @relation(fields: [relationshipId], references: [id])
  eventType       RelationshipEventType
  date            DateTime?
  datePrecision   DatePrecision @default(UNKNOWN)
  notes           String?
  createdAt       DateTime @default(now())

  @@index([relationshipId])
}

// ─── Organizations ────────────────────────────────────────────────────────────

model Network {
  id          String  @id @default(cuid())
  name        String
  nameNorm    String?
  description String?
  website     String?

  labelMemberships LabelNetworkLink[]

  @@index([name])
  @@index([nameNorm])
}

model Label {
  id          String  @id @default(cuid())
  name        String
  nameNorm    String?
  description String?
  website     String?

  networks        LabelNetworkLink[]
  projects        ProjectLabel[]
  primaryProjects Project[]          @relation("PrimaryLabel")
  sessions        Session[]
  channelMaps     ChannelLabelMap[]
  labelEvidence   SetLabelEvidence[]

  @@index([name])
  @@index([nameNorm])
}

model LabelNetworkLink {
  labelId   String
  label     Label   @relation(fields: [labelId], references: [id])
  networkId String
  network   Network @relation(fields: [networkId], references: [id])

  @@id([labelId, networkId])
  @@index([networkId])
  @@map("LabelNetwork")
}

model Channel {
  id        String  @id @default(cuid())
  name      String
  nameNorm  String?
  url       String?
  platform  String?
  notes     String?

  sets       Set[]
  labelMaps  ChannelLabelMap[]
  aliasLinks PersonAliasChannel[]

  @@index([nameNorm])
}

// ─── Evidence Layer ──────────────────────────────────────────────────────────

model ChannelLabelMap {
  channelId  String
  channel    Channel @relation(fields: [channelId], references: [id])
  labelId    String
  label      Label   @relation(fields: [labelId], references: [id])
  confidence Float   @default(1.0)
  notes      String?
  createdAt  DateTime @default(now())

  @@id([channelId, labelId])
}

model SetLabelEvidence {
  setId        String
  set          Set          @relation(fields: [setId], references: [id])
  labelId      String
  label        Label        @relation(fields: [labelId], references: [id])
  evidenceType EvidenceType
  confidence   Float        @default(1.0)
  notes        String?
  createdAt    DateTime     @default(now())

  @@id([setId, labelId, evidenceType])
}

// ─── Production ───────────────────────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String
  nameNorm    String?
  description String?
  status      ProjectStatus @default(active)
  tags        String[]
  labelId     String?
  label       Label?        @relation("PrimaryLabel", fields: [labelId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  labels   ProjectLabel[]
  sessions Session[]

  @@index([status])
  @@index([updatedAt])
  @@index([nameNorm])
  @@index([labelId])
}

model ProjectLabel {
  projectId String
  project   Project @relation(fields: [projectId], references: [id])
  labelId   String
  label     Label   @relation(fields: [labelId], references: [id])

  @@id([projectId, labelId])
}

model Session {
  id          String        @id @default(cuid())
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])
  labelId     String?
  label       Label?        @relation(fields: [labelId], references: [id])
  personId    String?       @unique
  person      Person?       @relation("ReferenceSession", fields: [personId], references: [id])
  name        String
  nameNorm    String?
  description String?
  location    String?
  type        SessionType   @default(PRODUCTION)
  status      SessionStatus @default(DRAFT)
  notes       String?
  date        DateTime?
  datePrecision DatePrecision @default(UNKNOWN)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  mediaItems      MediaItem[]
  contributions   SessionContribution[]
  setSessionLinks SetSession[]

  @@index([projectId])
  @@index([labelId])
  @@index([personId])
  @@index([date])
  @@index([type])
  @@index([status])
  @@index([nameNorm])
}

model Set {
  id          String    @id @default(cuid())
  channelId   String?
  channel     Channel?  @relation(fields: [channelId], references: [id])
  type        SetType
  title       String
  titleNorm   String?
  description String?
  notes       String?
  releaseDate DateTime?
  releaseDatePrecision DatePrecision @default(UNKNOWN)
  coverMediaItemId String?
  coverMediaItem   MediaItem? @relation("SetCoverMedia", fields: [coverMediaItemId], references: [id])
  category    String?
  genre       String?
  tags        String[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  setMediaItems   SetMediaItem[]
  creditsRaw      SetCreditRaw[]
  participants    SetParticipant[]
  labelEvidence   SetLabelEvidence[]
  sessionLinks    SetSession[]

  @@index([channelId])
  @@index([type])
  @@index([releaseDate])
  @@index([titleNorm])
  @@index([coverMediaItemId])
}

// ─── Media ───────────────────────────────────────────────────────────────────

model MediaItem {
  id          String    @id @default(cuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id])
  mediaType   MediaType
  capturedAt  DateTime?
  capturedAtPrecision DatePrecision @default(UNKNOWN)

  filename       String
  fileRef        String?
  mimeType       String
  size           Int
  hash           String?
  phash          String?
  originalWidth  Int
  originalHeight Int
  durationMs     Int?
  variants       Json?

  focalX        Float?
  focalY        Float?
  focalSource   String?
  focalStatus   String?
  modelVersion  String?

  caption    String?
  tags       String[]
  notes      String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  setMediaItems    SetMediaItem[]
  personMediaLinks PersonMediaLink[]
  coverForSets     Set[]             @relation("SetCoverMedia")
  collectionItems  MediaCollectionItem[]
  skillEventMedia  SkillEventMedia[]

  @@index([sessionId])
  @@index([hash])
  @@index([phash])
  @@index([mediaType])
  @@index([tags], type: Gin)
}

model SetMediaItem {
  setId       String
  set         Set       @relation(fields: [setId], references: [id])
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id])
  sortOrder   Int       @default(0)
  isCover     Boolean   @default(false)
  caption     String?
  notes       String?

  @@id([setId, mediaItemId])
}

model SessionContribution {
  id                 String                     @id @default(cuid())
  sessionId          String
  session            Session                    @relation(fields: [sessionId], references: [id])
  personId           String
  person             Person                     @relation(fields: [personId], references: [id])
  roleDefinitionId   String
  roleDefinition     ContributionRoleDefinition @relation(fields: [roleDefinitionId], references: [id])
  creditNameOverride String?
  notes              String?
  createdAt          DateTime                   @default(now())

  skills             ContributionSkill[]

  @@unique([sessionId, personId, roleDefinitionId])
  @@index([sessionId])
  @@index([personId])
  @@index([roleDefinitionId])
}

model SetParticipant {
  setId            String
  set              Set                        @relation(fields: [setId], references: [id])
  personId         String
  person           Person                     @relation(fields: [personId], references: [id])
  roleDefinitionId String
  roleDefinition   ContributionRoleDefinition @relation(fields: [roleDefinitionId], references: [id])

  @@id([setId, personId, roleDefinitionId])
  @@index([roleDefinitionId])
}

model SetSession {
  setId     String
  set       Set     @relation(fields: [setId], references: [id])
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id])
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  @@id([setId, sessionId])
}

model SetCreditRaw {
  id               String                      @id @default(cuid())
  setId            String
  set              Set                          @relation(fields: [setId], references: [id])
  roleDefinitionId String?
  roleDefinition   ContributionRoleDefinition?  @relation(fields: [roleDefinitionId], references: [id])
  rawName          String
  nameNorm         String?   @map("rawNameNorm")
  resolutionStatus ResolutionStatus @default(UNRESOLVED)
  resolvedPersonId String?
  resolvedPerson   Person?          @relation(fields: [resolvedPersonId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([setId])
  @@index([resolutionStatus])
  @@index([nameNorm])
  @@index([resolvedPersonId])
  @@index([roleDefinitionId])
}

model PersonMediaLink {
  id          String           @id @default(cuid())
  personId    String
  person      Person           @relation(fields: [personId], references: [id])
  mediaItemId String
  mediaItem   MediaItem        @relation(fields: [mediaItemId], references: [id])
  usage       PersonMediaUsage
  isFavorite  Boolean          @default(false)
  sortOrder   Int              @default(0)
  notes       String?

  slot                 Int?
  bodyRegion           String?
  bodyRegions          String[]
  bodyMarkId           String?
  bodyMark             BodyMark?           @relation(fields: [bodyMarkId], references: [id])
  bodyModificationId   String?
  bodyModification     BodyModification?   @relation(fields: [bodyModificationId], references: [id])
  cosmeticProcedureId  String?
  cosmeticProcedure    CosmeticProcedure?  @relation(fields: [cosmeticProcedureId], references: [id])
  categoryId           String?
  category             MediaCategory?      @relation(fields: [categoryId], references: [id])
  personaId            String?
  persona              Persona?            @relation(fields: [personaId], references: [id], onDelete: SetNull)

  createdAt   DateTime         @default(now())

  @@unique([personId, mediaItemId, usage])
  @@index([personId])
  @@index([mediaItemId])
  @@index([bodyMarkId])
  @@index([bodyModificationId])
  @@index([cosmeticProcedureId])
  @@index([personaId])
  @@index([categoryId])
}

// ─── Media Collections ──────────────────────────────────────────────────────

model MediaCollection {
  id          String                @id @default(uuid())
  name        String
  description String?
  personId    String?
  person      Person?               @relation(fields: [personId], references: [id])
  items       MediaCollectionItem[]
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([personId])
  @@map("MediaCollection")
}

model MediaCollectionItem {
  collectionId String
  mediaItemId  String
  sortOrder    Int              @default(0)
  collection   MediaCollection  @relation(fields: [collectionId], references: [id])
  mediaItem    MediaItem        @relation(fields: [mediaItemId], references: [id])
  createdAt    DateTime         @default(now())

  @@id([collectionId, mediaItemId])
  @@index([mediaItemId])
  @@map("MediaCollectionItem")
}

// ─── Media Categories ────────────────────────────────────────────────────────

model MediaCategoryGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  categories MediaCategory[]

  @@index([sortOrder])
}

model MediaCategory {
  id          String   @id @default(cuid())
  groupId     String
  group       MediaCategoryGroup @relation(fields: [groupId], references: [id])
  name        String
  slug        String   @unique
  entityModel String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  personMediaLinks PersonMediaLink[]

  @@unique([groupId, name])
  @@index([groupId])
  @@index([sortOrder])
}

// ─── Physical Attribute Catalog ──────────────────────────────────────────────

model PhysicalAttributeGroup {
  id          String                       @id @default(cuid())
  name        String                       @unique
  sortOrder   Int                          @default(0)
  createdAt   DateTime                     @default(now())

  definitions PhysicalAttributeDefinition[]

  @@index([sortOrder])
}

model PhysicalAttributeDefinition {
  id        String                  @id @default(cuid())
  groupId   String
  group     PhysicalAttributeGroup  @relation(fields: [groupId], references: [id])
  name      String
  slug      String                  @unique
  unit      String?
  sortOrder Int                     @default(0)
  createdAt DateTime                @default(now())

  attributes          PersonaPhysicalAttribute[]
  cosmeticProcedures  CosmeticProcedure[]

  @@unique([groupId, name])
  @@index([groupId])
  @@index([sortOrder])
}

model PersonaPhysicalAttribute {
  id                    String                       @id @default(cuid())
  personaPhysicalId     String
  personaPhysical       PersonaPhysical              @relation(fields: [personaPhysicalId], references: [id])
  attributeDefinitionId String
  attributeDefinition   PhysicalAttributeDefinition  @relation(fields: [attributeDefinitionId], references: [id])
  value                 String

  @@unique([personaPhysicalId, attributeDefinitionId])
  @@index([personaPhysicalId])
  @@index([attributeDefinitionId])
}

// ─── System ───────────────────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Activity {
  id    String       @id @default(cuid())
  title String
  time  DateTime
  type  ActivityType

  createdAt DateTime  @default(now())

  @@index([time])
  @@index([type])
}

// ─── Skill Catalog & Tracking ────────────────────────────────────────────────

model SkillGroup {
  id          String            @id @default(cuid())
  name        String            @unique
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  definitions SkillDefinition[]

  @@index([sortOrder])
}

model SkillDefinition {
  id          String     @id @default(cuid())
  groupId     String
  group       SkillGroup @relation(fields: [groupId], references: [id])
  name        String
  slug        String     @unique
  description  String?
  pgrade       Int        @default(0)
  defaultLevel SkillLevel?
  sortOrder    Int        @default(0)
  createdAt   DateTime   @default(now())

  personSkills             PersonSkill[]
  contributionSkills       ContributionSkill[]

  @@unique([groupId, name])
  @@index([groupId])
  @@index([sortOrder])
}

model PersonSkillEvent {
  id            String         @id @default(cuid())
  personSkillId String
  personSkill   PersonSkill    @relation(fields: [personSkillId], references: [id])
  personaId     String?
  persona       Persona?       @relation(fields: [personaId], references: [id])
  eventType     SkillEventType
  level         SkillLevel?
  date          DateTime?
  datePrecision DatePrecision  @default(UNKNOWN)
  notes         String?
  createdAt     DateTime       @default(now())

  media         SkillEventMedia[]

  @@index([personSkillId])
  @@index([personaId])
}

model SkillEventMedia {
  skillEventId String
  mediaItemId  String
  sortOrder    Int              @default(0)
  skillEvent   PersonSkillEvent @relation(fields: [skillEventId], references: [id])
  mediaItem    MediaItem        @relation(fields: [mediaItemId], references: [id])
  createdAt    DateTime         @default(now())

  @@id([skillEventId, mediaItemId])
  @@index([mediaItemId])
}

// ─── Contribution Role Catalog ───────────────────────────────────────────────

model ContributionRoleGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  definitions ContributionRoleDefinition[]

  @@index([sortOrder])
}

model ContributionRoleDefinition {
  id            String                @id @default(cuid())
  groupId       String
  group         ContributionRoleGroup @relation(fields: [groupId], references: [id])
  name          String
  slug          String                @unique
  description   String?
  sortOrder     Int                   @default(0)
  createdAt     DateTime              @default(now())

  contributions   SessionContribution[]
  setCreditRaws   SetCreditRaw[]
  setParticipants SetParticipant[]

  @@unique([groupId, name])
  @@index([groupId])
  @@index([sortOrder])
}

model ContributionSkill {
  id                String              @id @default(cuid())
  contributionId    String
  contribution      SessionContribution @relation(fields: [contributionId], references: [id])
  skillDefinitionId String
  skillDefinition   SkillDefinition     @relation(fields: [skillDefinitionId], references: [id])
  level             SkillLevel?
  notes             String?
  createdAt         DateTime            @default(now())

  @@unique([contributionId, skillDefinitionId])
  @@index([contributionId])
  @@index([skillDefinitionId])
}
